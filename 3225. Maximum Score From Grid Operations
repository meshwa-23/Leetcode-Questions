class Solution {
    public long maximumScore(int[][] grid) {
        int n = grid.length;
        
        // prefix sum for each column
        long[][] colPrefix = new long[n][n + 1];
        for (int j = 0; j < n; j++) {
            for (int i = 0; i < n; i++) {
                colPrefix[j][i + 1] = colPrefix[j][i] + grid[i][j];
            }
        }

        // dp[c][h]
        long[][] dp = new long[n][n + 1];

        // initialize first column (no contribution possible)
        for (int h = 0; h <= n; h++) {
            dp[0][h] = 0;
        }

        for (int c = 1; c < n; c++) {
            for (int h = 0; h <= n; h++) {
                long best = 0;

                for (int prev = 0; prev <= n; prev++) {
                    long gain = 0;

                    // overlapping white cells that get adjacent black
                    int minH = Math.min(h, prev);
                    int maxH = Math.max(h, prev);

                    // contribution: cells between minH and maxH
                    if (h > prev) {
                        gain = colPrefix[c - 1][h] - colPrefix[c - 1][prev];
                    } else if (prev > h) {
                        gain = colPrefix[c][prev] - colPrefix[c][h];
                    }

                    best = Math.max(best, dp[c - 1][prev] + gain);
                }

                dp[c][h] = best;
            }
        }

        long ans = 0;
        for (int h = 0; h <= n; h++) {
            ans = Math.max(ans, dp[n - 1][h]);
        }

        return ans;
    }
}
